# Copy this file to `.env`, then paste your OpenRouter API key.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# The embedding model turns text into vectors for similarity search.
# Keep this configurable because provider model names and free tiers can change.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# The chat model writes final answers. Pick a current OpenRouter free chat model
# if this default is unavailable in your account.
OPENROUTER_CHAT_MODEL=openai/gpt-oss-20b:free

